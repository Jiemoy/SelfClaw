{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SelfClaw",
  "version": "0.1.0",
  "identifier": "com.selfclaw.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SelfClaw - AI 助手",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN",
        "upgradeCode": "7c7f1f6a-7b7c-4a7a-9a7b-7c7f1f6a7b7c",
        "bannerPath": null,
        "dialogImagePath": null
      }
    }
  },
  "plugins": {}
}
